PORT=3000

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=grocery_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Firebase Admin Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com

# Support SMTP Configuration
SUPPORT_SMTP_USER=support@freshsabjihub.com
SUPPORT_SMTP_PASS=your_support_password_here

# Storage Configuration (Optional, for persistent storage on Hostinger or custom locations)
# UPLOAD_DIR=/path/to/persistent/uploads/folder
# BASE_URL=https://your-domain.com

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
